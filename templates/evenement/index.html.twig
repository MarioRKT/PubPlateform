{% extends 'base.html.twig' %}

{% block title %}Evenement index
{% endblock %}


{% block body %}
	<div class="p-8">
		<!-- En-tête avec titre et bouton de création alignés -->
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
			<div>
				<h1 class="text-xl font-bold text-slate-800 tracking-tight uppercase">Liste des Événements</h1>
				<p class="text-sm text-slate-500 mt-1">Consultez, modifiez et gérez les événements de la plateforme.</p>
			</div>
			<a href="{{ path('admin_evenement_new') }}" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm py-2.5 px-4 rounded-xl shadow-lg shadow-blue-500/10 transition-all transform hover:-translate-y-0.5">
				<i class="fa-solid fa-plus"></i>
				Créer un nouvel événement
			</a>
		</div>

		<!-- Conteneur responsive du tableau -->
		<div class="overflow-x-auto bg-white rounded-2xl border border-slate-100 shadow-sm mt-16">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-slate-50 border-b border-slate-100 text-xs font-semibold text-slate-500 uppercase tracking-wider">
						<th class="py-4 px-6">Id</th>
						<th class="py-4 px-6">Événement & Artiste</th>
						<th class="py-4 px-6">Date & Heure</th>
						<th class="py-4 px-6">Lieu</th>
						<th class="py-4 px-6">Prix Billet</th>
						<th class="py-4 px-6">Description</th>
						<th class="py-4 px-6">Image</th>
						<th class="py-4 px-6">Catégorie</th>
						<th class="py-4 px-6">Statut</th>
						<th class="py-4 px-6">Date Création</th>
						<th class="py-4 px-6 text-right">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-100 text-sm">
					{% for evenement in evenements %}
						<tr
							class="hover:bg-slate-50/50 transition-colors">
							<!-- ID -->
							<td class="py-4 px-6 text-slate-400 font-mono text-xs">
								#{{ evenement.id }}
							</td>

							<!-- Titre & Artiste fusionnés élégamment -->
							<td class="py-4 px-6">
								<p class="font-semibold text-slate-800">{{ evenement.titre }}</p>
								<p class="text-xs text-[#F96C2F] font-medium">{{ evenement.artiste }}</p>
							</td>

							<!-- Date & Heure -->
							<td class="py-4 px-6 text-slate-600">
								<div class="flex flex-col">
									<span class="font-medium">{{ evenement.dateEvenement ? evenement.dateEvenement|date('d M Y') : 'N/A' }}</span>
									<span class="text-xs text-slate-400">{{ evenement.heureEvenement ? evenement.heureEvenement|date('H:i') : '' }}</span>
								</div>
							</td>

							<!-- Lieu -->
							<td class="py-4 px-6 text-slate-600 font-medium">
								{{ evenement.lieu }}
							</td>

							<!-- Prix Billet -->
							<td class="py-4 px-6">
								<span class="text-slate-800 font-semibold bg-slate-50 border border-slate-150 px-2 py-1 rounded-md text-xs">
									{{ evenement.prixBillet }}
									Ar
								</span>
							</td>

							<!-- Description tronquée pour ne pas casser la mise en page -->
							<td class="py-4 px-6 text-slate-400 max-w-xs truncate" title="{{ evenement.description }}">
								{{ evenement.description }}
							</td>

							<!-- Image URL/Nom -->
							<td class="py-4 px-6 text-xs text-slate-400 font-mono max-w-[120px] truncate" title="{{ evenement.image }}">
								{{ evenement.image }}
							</td>

							<!-- Catégorie (Style Badge neutre) -->
							<td class="py-4 px-6">
								<span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-gray-50 text-gray-600 border border-gray-150">
									{{ evenement.categorie }}
								</span>
							</td>

							<!-- Actif (Badge dynamique aux couleurs du thème) -->
							<td class="py-4 px-6">
								{% if evenement.actif %}
									<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
										<span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
										Actif
									</span>
								{% else %}
									<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-50 text-rose-700">
										<span class="h-1.5 w-1.5 rounded-full bg-rose-400"></span>
										Inactif
									</span>
								{% endif %}
							</td>

							<!-- Date Création -->
							<td class="py-4 px-6 text-xs text-slate-400">
								{{ evenement.dateCreation ? evenement.dateCreation|date('d/m/Y H:i') : '' }}
							</td>

							<!-- Actions de droite réorganisées sous forme d'icônes -->
							<td class="py-4 px-6 text-right">
								<div
									class="inline-flex items-center gap-2">
									{# Voir #}
									<a href="{{ path('admin_evenement_show', {'id': evenement.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Voir">
										<i class="fa-solid fa-eye"></i>
									</a>
									{# Modifier #}
									<a href="{{ path('admin_evenement_edit', {'id': evenement.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Modifier">
										<i class="fa-solid fa-pen-to-square"></i>
									</a>

									{{ include('evenement/_delete_form.html.twig') }}
								</div>
							</td>
						</tr>
					{% else %}
						<!-- État vide (Aucun record trouvé) -->
						<tr>
							<td colspan="11" class="py-12 text-center text-slate-400">
								<i class="fa-regular fa-folder-open text-4xl mb-3 block text-slate-300"></i>
								Aucun événement trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
