<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Accueil utilisateur
			{% endblock %}
		</title>
		<!-- FontAwesome & Tailwind pour un rendu élégant global -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
		<script src="https://cdn.tailwindcss.com"></script>

		{% block stylesheets %}
			<link rel="stylesheet" href="/css/output.css">
		{% endblock %}
	</head>
	<body>
		{% block body %}
			{% if is_granted('ROLE_USER') %}
				<!-- NAVBAR -->
				<nav class="bg-white border-b border-gray-100 shadow-sm sticky top-0 z-50 transition-all duration-300">
					<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
						<div class="flex justify-between h-16">

							<div class="flex items-center gap-8">
								<div class="flex-shrink-0 flex items-center gap-2">
									<div class="h-9 w-9 rounded-xl bg-[#F96C2F] flex items-center justify-center text-white shadow-md shadow-[#F96C2F]/20">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.68-.69-1.8-1.04-3.07-1.04s-2.39.35-3.07 1.04c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07zM21.25 15.84c-.69-.69-1.8-1.04-3.07-1.04s-2.39.35-3.07 1.04c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07zM10.34 4.94c-.68-.69-1.8-1.04-3.07-1.04S4.88 4.25 4.2 4.94c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07z"/>
										</svg>
									</div>
									<span class="text-lg font-bold text-gray-900 tracking-tight">Pub<span class="text-[#F96C2F]">Platform</span>
									</span>
								</div>

								<!-- Liens de navigation avec le nouvel accent coloré et fond pastel -->
								<div class="hidden md:flex items-center gap-1">
									<a href="/" class="px-4 py-2 rounded-xl text-sm font-medium text-[#F96C2F] bg-[#F96C2F]/10 transition-all">Accueil</a>
									<a href="/evenements" class="px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-all">Événements</a>
									<a href="/activites" class="px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-all">Activités</a>
									<a href="/trouver-un-lieu" class="px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-all">Trouver un lieu</a>
								</div>
							</div>

							<div class="hidden md:flex items-center gap-4">
								{% if app.user %}
									<div
										class="flex items-center gap-3 bg-gray-50 p-1.5 pr-4 rounded-xl border border-gray-100">
										<!-- Avatar aux couleurs du projet -->
										<div class="h-8 w-8 rounded-lg bg-[#F96C2F] text-white flex items-center justify-center text-xs font-semibold uppercase shadow-sm">
											{{ app.user.prenom|slice(0, 1) }}{{ app.user.nom|slice(0, 1) }}
										</div>
										<div class="flex flex-col">
											<span class="text-xs text-gray-400 leading-none">Client connecté</span>
											<span class="text-sm font-medium text-gray-700 leading-tight">{{ app.user.prenom }}
												{{ app.user.nom }}</span>
										</div>
									</div>
									<a href="/logout" class="p-2 rounded-xl text-gray-400 hover:text-red-500 hover:bg-red-50 transition-all" title="Déconnexion">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
										</svg>
									</a>
								{% endif %}
							</div>

							<div class="flex items-center md:hidden">
								<button type="button" class="inline-flex items-center justify-center p-2 rounded-xl text-gray-500 hover:text-gray-900 hover:bg-gray-50 focus:outline-none transition-all">
									<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
									</svg>
								</button>
							</div>

						</div>
					</div>

					<!-- MENU MOBILE -->
					<div class="hidden md:hidden border-t border-gray-100 bg-white px-4 pt-2 pb-4 space-y-1.5">
						<a href="/" class="block px-4 py-2.5 rounded-xl text-sm font-medium text-[#F96C2F] bg-[#F96C2F]/10">Accueil</a>
						<a href="/evenements" class="block px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Événements</a>
						<a href="/activites" class="block px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Activités</a>
						<a href="/trouver-un-lieu" class="block px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50">Trouver un lieu</a>

						{% if app.user %}
							<div class="pt-4 mt-4 border-t border-gray-100 flex items-center justify-between">
								<div class="text-sm font-medium text-gray-800">{{ app.user.prenom }}
									{{ app.user.nom }}</div>
								<a href="/logout" class="text-sm font-medium text-red-600 hover:text-red-700">Déconnexion</a>
							</div>
						{% endif %}
					</div>
				</nav>

				<!-- HERO SECTION -->
				<section
					class="relative min-h-screen flex items-center bg-gray-900 text-white overflow-hidden">

					<!-- 1. L'image de fond (Nette, mais semi-transparente) -->
					<div class="absolute inset-0 z-0 bg-cover bg-center opacity-40 scale-105" style="background-image: url('{{ asset('images/MAHALEO_TARANAKA.png') }}');"></div>

					<div class="relative z-10 max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8 w-full">
						<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

							<div class="lg:col-span-7 space-y-6">
								<h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white uppercase">
									MAHALEO TARANAKA
								</h1>

								<!-- Icônes informatives passées au orange #F96C2F -->
								<div class="space-y-3 text-gray-300">
									<div class="flex items-center gap-3 text-sm sm:text-base">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-[#F96C2F]">
											<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
										</svg>
										<span>29 Juin 2026</span>
									</div>

									<div class="flex items-center gap-3 text-sm sm:text-base">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-[#F96C2F]">
											<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
											<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1115 0z"/>
										</svg>
										<span>O'frais - Mahazoarivo</span>
									</div>

									<div class="flex items-center gap-3 text-sm sm:text-base">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-[#F96C2F]">
											<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
										</svg>
										<span>21:00</span>
									</div>

									<div class="flex items-center gap-3 text-sm sm:text-base font-medium">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-yellow-500">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a2.25 2.25 0 003.182 0l4.318-4.318a2.25 2.25 0 000-3.182L11.16 3.659A2.25 2.25 0 009.568 3z"/>
											<path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
										</svg>
										<span class="text-yellow-400">40.000 Ar</span>
									</div>
								</div>

								<!-- Bouton principal mis à jour en Orange Projet -->
								<div class="flex flex-col sm:flex-row gap-4 pt-4">
									<button class="bg-[#F96C2F] hover:bg-[#e05316] text-white font-semibold py-3.5 px-6 rounded-xl shadow-lg shadow-[#F96C2F]/20 transition-all  focus:outline-none  text-center">
										Réserver maintenant
									</button>

									<button class="bg-white/10 hover:bg-white/15 border border-white/20 text-white font-medium py-3.5 px-6 rounded-xl transition-all backdrop-blur-sm text-center">
										En savoir plus
									</button>
								</div>
							</div>

						</div>
					</div>
				</section>

				<!-- FOOTER -->
				<footer class="bg-white border-t border-gray-100 mt-auto">
					<div class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">

						<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

							<div class="space-y-4">
								<div class="flex items-center gap-2">
									<div class="h-8 w-8 rounded-xl bg-[#F96C2F] flex items-center justify-center text-white shadow-md shadow-[#F96C2F]/20">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
											<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.68-.69-1.8-1.04-3.07-1.04s-2.39.35-3.07 1.04c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07zM21.25 15.84c-.69-.69-1.8-1.04-3.07-1.04s-2.39.35-3.07 1.04c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07zM10.34 4.94c-.68-.69-1.8-1.04-3.07-1.04S4.88 4.25 4.2 4.94c-.69.68-1.04 1.8-1.04 3.07s.35 2.39 1.04 3.07c.68.69 1.8 1.04 3.07 1.04s2.39-.35 3.07-1.04c.69-.68 1.04-1.8 1.04-3.07s-.35-2.39-1.04-3.07z"/>
										</svg>
									</div>
									<span class="text-base font-bold text-gray-900 tracking-tight">Pub<span class="text-[#F96C2F]">Platform</span>
									</span>
								</div>
								<p class="text-sm text-gray-500 max-w-sm leading-relaxed">
									Votre plateforme publicitaire de confiance pour booster votre visibilité et connecter vos projets.
								</p>
							</div>

							<div>
								<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">À propos</h3>
								<ul class="space-y-2">
									<li>
										<a href="/qui-sommes-nous" class="text-sm text-gray-500 hover:text-[#F96C2F] transition-colors">Qui sommes-nous ?</a>
									</li>
									<li>
										<a href="/mentions-legales" class="text-sm text-gray-500 hover:text-[#F96C2F] transition-colors">Mentions légales</a>
									</li>
									<li>
										<a href="/conditions-utilisation" class="text-sm text-gray-500 hover:text-[#F96C2F] transition-colors">Conditions d'utilisation</a>
									</li>
								</ul>
							</div>

							<div>
								<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Nous contacter</h3>
								<ul class="space-y-3">
									<li class="flex items-center gap-2.5">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-[#F96C2F] shrink-0">
											<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5A2.25 2.25 0 012.25 17.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0l-7.5-4.615a2.25 2.25 0 01-1.07-1.916V6.75"/>
										</svg>
										<a href="mailto:service-client@atout-service-mada.com" class="text-sm text-gray-500 hover:text-[#F96C2F] transition-colors break-all">
											service-client@atout-service-mada.com
										</a>
									</li>
									<li class="flex items-center gap-2.5">
										<svg xmlns="http://www.w3.org/2000/xl" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-[#F96C2F] shrink-0">
											<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.635-5.165-3.976-6.791-6.791l1.293-.97c.362-.271.528-.733.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
										</svg>
										<a href="tel:0344405577" class="text-sm text-gray-500 hover:text-[#F96C2F] transition-colors">
											034 44 055 77
										</a>
									</li>
									<li class="flex items-start gap-2.5">
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-[#F96C2F] shrink-0 mt-0.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
											<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1115 0z"/>
										</svg>
										<span class="text-sm text-gray-500 leading-relaxed">
											Lot VC 67 Bis Ambohidahy - Amparibe,<br>Antananarivo, Madagascar
										</span>
									</li>
								</ul>
							</div>

						</div>

						<div class="pt-8 border-t border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
							<p class="text-xs text-gray-400">
								&copy;
								{{ "now"|date("Y") }}
								PubPlatform. Tous droits réservés.
							</p>
							<div
								class="flex gap-4">
								<!-- Ajustement du badge final -->
								<span class="text-xs font-semibold px-2.5 py-1 rounded-md bg-[#F96C2F]/10 text-[#F96C2F]">Atout Service Mada</span>
							</div>
						</div>

					</div>
				</footer>
			{% else %}
				<p>Accès interdit.</p>
			{% endif %}
		{% endblock %}
	</body>
</html>
