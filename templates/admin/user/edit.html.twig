{% extends 'base.html.twig' %}

{% block title %}Modifier l'utilisateur
{% endblock %}

{% block body %}
	<div class="flex justify-center items-center h-screen">
		<div class="h-fit bg-white rounded-2xl shadow-xl border border-gray-100 p-8">

			<div class="text-center mb-8">
				<div class="mx-auto flex items-center justify-center h-12 w-12 rounded-xl bg-blue-50 text-blue-600 mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
					</svg>
				</div>
				<h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Modifier l'utilisateur</h1>
				<p class="text-sm text-gray-500 mt-2">Mise à jour du profil de
					<span class="font-semibold text-blue-600">{{ user.prenom }}
						{{ user.nom }}</span>
				</p>
			</div>

			{{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				<div>
					{{ form_label(form.prenom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1.5'}}) }}
					{{ form_widget(form.prenom, {'attr': {'class': 'block w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-sm'}}) }}
					{% if form_errors(form.prenom) %}
						<div class="text-xs text-red-600 mt-1">{{ form_errors(form.prenom) }}</div>
					{% endif %}
				</div>

				<div>
					{{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1.5'}}) }}
					{{ form_widget(form.nom, {'attr': {'class': 'block w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-sm'}}) }}
					{% if form_errors(form.nom) %}
						<div class="text-xs text-red-600 mt-1">{{ form_errors(form.nom) }}</div>
					{% endif %}
				</div>
			</div>

			<div>
				{{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1.5'}}) }}
				{{ form_widget(form.email, {'attr': {'class': 'block w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-sm'}}) }}
				{% if form_errors(form.email) %}
					<div class="text-xs text-red-600 mt-1">{{ form_errors(form.email) }}</div>
				{% endif %}
			</div>

			<div>
				{{ form_label(form.password, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1.5'}}) }}
				{{ form_widget(form.password, {'attr': {'class': 'block w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-sm'}}) }}
				{% if form_errors(form.password) %}
					<div class="text-xs text-red-600 mt-1">{{ form_errors(form.password) }}</div>
				{% endif %}
			</div>

			<div>
				{{ form_label(form.roles, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
				<div class="flex flex-col sm:flex-row gap-4 p-4 rounded-xl bg-gray-50 border border-gray-200">
					{% for child in form.roles %}
						<div class="flex items-center gap-3">
							{{ form_widget(child, {'attr': {'class': 'h-5 w-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 transition-colors cursor-pointer'}}) }}
							{{ form_label(child, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 cursor-pointer select-none'}}) }}
						</div>
					{% endfor %}
				</div>
				{% if form_errors(form.roles) %}
					<div class="text-xs text-red-600 mt-1">{{ form_errors(form.roles) }}</div>
				{% endif %}
			</div>

			<div class="pt-2">
				<button type="submit" class="w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-xl shadow-lg shadow-blue-500/20 transition-all transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
					Mettre à jour
				</button>
			</div>

			{{ form_end(form) }}

			<div class="text-center mt-6">
				<a href="{{ path('admin_dashboard') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700 inline-flex items-center gap-1 transition-colors">
					Retour au tableau de bord
				</a>
			</div>
		</div>
	</div>
	{% endblock %}
