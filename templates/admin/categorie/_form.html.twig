{# Petit script natif pour gérer le remplacement dynamique de l'icône par le fichier sélectionné #}
<script>
function previewFile(input) {
    const file = input.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const placeholder = document.getElementById('preview-placeholder');
            const wrapper = document.getElementById('preview-image-wrapper');
            const imgElements = document.querySelectorAll('#preview-image');
            
            // On met à jour la source de l'image (pour la création ou l'édition)
            imgElements.forEach(img => {
                img.src = e.target.result;
            });

            // Si on était en création (icône présente), on permute les affichages
            if (placeholder && wrapper) {
                placeholder.classList.add('hidden');
                wrapper.classList.remove('hidden');
            }
        }
        reader.readAsDataURL(file);
    }
}
</script>