{% extends 'base.html.twig' %}

{% block title %}Nouveau Menu | Admin{% endblock %}

{% block body %}
<div class="p-6 w-full mx-auto">
    <!-- En-tête de la page -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Créer un nouveau menu</h1>
        <p class="text-sm text-slate-500 mt-1">Configurez les paramètres et l'ordre d'apparition du nouvel élément de navigation.</p>
    </div>

    <!-- Conteneur blanc du formulaire -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200/80 p-6">
        {{ include('admin/menu/_form.html.twig') }}
    </div>
</div>
{% endblock %}