<form method="post" action="{{ path('admin_menu_delete', {'id': menu.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ menu.id) }}">
    <button class="btn"><i class="fa-solid fa-trash text-red-500 rounded-full bg-rose-200 p-1"></i></button>
</form>
