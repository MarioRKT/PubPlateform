{% extends 'base.html.twig' %}

{% block title %}Menu index
{% endblock %}

{% block body %}
	<div class="p-8">
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
			<div>
				<h1 class="text-xl font-bold text-slate-800 tracking-tight uppercase">Configuration du Menu</h1>
				<p class="text-sm text-slate-500 mt-1">Consultez, organisez et gérez les liens de navigation de la plateforme.</p>
			</div>
			<a href="{{ path('admin_menu_new') }}" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm py-2.5 px-4 rounded-xl shadow-lg shadow-blue-500/10 transition-all transform hover:-translate-y-0.5">
				<i class="fa-solid fa-plus"></i>
				Créer un nouveau menu
			</a>
		</div>

		<div class="overflow-x-auto bg-white rounded-2xl border border-slate-100 shadow-sm mt-16">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-slate-50 border-b border-slate-100 text-xs font-semibold text-slate-500 uppercase tracking-wider">
						<th class="py-4 px-6">Id</th>
						<th class="py-4 px-6">Nom</th>
						<th class="py-4 px-6">Status</th>
						<th class="py-4 px-6">Type Lien</th>
						<th class="py-4 px-6">Ordre</th>
						<th class="py-4 px-6 text-right">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-100 text-sm">
					{% for menu in menus %}
						<tr class="hover:bg-slate-50/50 transition-colors">
							<td class="py-4 px-6 text-slate-400 font-mono text-xs">
								#{{ menu.id }}
							</td>

							<td class="py-4 px-6 font-semibold text-slate-800">
								{{ menu.nom }}
							</td>

							<td class="py-4 px-6">
								{% if menu.status %}
									<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
										<span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
										Actif
									</span>
								{% else %}
									<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-50 text-rose-700">
										<span class="h-1.5 w-1.5 rounded-full bg-rose-400"></span>
										Inactif
									</span>
								{% endif %}
							</td>

							<td class="py-4 px-6">
								<span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-gray-50 text-gray-600 border border-gray-150">
									{{ menu.typeLien }}
								</span>
							</td>

							<td class="py-4 px-6 text-slate-600 font-mono font-medium">
								{{ menu.ordre }}
							</td>

							<td class="py-4 px-6 text-right">
								<div
									class="inline-flex items-center gap-2">
									{# Voir #}
									<a href="{{ path('admin_menu_show', {'id': menu.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Voir">
										<i class="fa-solid fa-eye"></i>
									</a>
									{# Modifier #}
									<a href="{{ path('admin_menu_edit', {'id': menu.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Modifier">
										<i class="fa-solid fa-pen-to-square"></i>
									</a>
                                    {{ include('admin/menu/_delete_form.html.twig') }}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="6" class="py-12 text-center text-slate-400">
								<i class="fa-regular fa-folder-open text-4xl mb-3 block text-slate-300"></i>
								Aucun enregistrement trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
