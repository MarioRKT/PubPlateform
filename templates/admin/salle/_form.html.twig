{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

{# Message d'erreurs globales #}
{% if form.vars.errors|length > 0 %}
    <div class="p-4 rounded-xl bg-rose-50 border border-rose-200 text-sm text-rose-700 flex items-start gap-2 animate-fade-in">
        <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
        <div>
            <span class="font-semibold">Veuillez corriger les anomalies du formulaire :</span>
            {{ form_errors(form) }}
        </div>
    </div>
{% endif %}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    {# --- Champ : Nom de la salle --- #}
    <div>
        {{ form_label(form.nom, 'Nom de la salle', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.nom, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900',
            'placeholder': 'Ex: Grande Salle Impériale'
        }}) }}
        {% if form.nom.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.nom) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Type de salle (EntityType) --- #}
    <div>
        {{ form_label(form.typeSalle, 'Type de salle', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.typeSalle, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900 bg-white'
        }}) }}
        {% if form.typeSalle.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.typeSalle) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Lieu --- #}
    <div>
        {{ form_label(form.lieu, 'Lieu / Emplacement', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.lieu, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900',
            'placeholder': 'Ex: Étage 2, Bloc B'
        }}) }}
        {% if form.lieu.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.lieu) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Limite de places (Integer) --- #}
    <div>
        {{ form_label(form.limitePlace, 'Limite de places', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.limitePlace, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900',
            'placeholder': 'Ex: 150'
        }}) }}
        {% if form.limitePlace.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.limitePlace) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Ordre de Tri (Integer) --- #}
    <div>
        {{ form_label(form.tri, 'Ordre de tri', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.tri, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900',
            'placeholder': 'Ex: 1, 2, 3...'
        }}) }}
        {% if form.tri.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.tri) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Aperçu photo (FileType mapped:false) --- #}
    <div class="bg-slate-50/50 p-3 rounded-2xl border border-slate-200 flex flex-col justify-end">
        {{ form_label(form.apercuFile, 'Aperçu (photo)', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.apercuFile, {'attr': {
            'class': 'w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-all cursor-pointer'
        }}) }}
        {% if form.apercuFile.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.apercuFile) }}
            </div>
        {% endif %}
    </div>

    {# --- Case à cocher : Statut Actif --- #}
    <div class="flex items-center gap-3 bg-slate-50 p-4 rounded-xl border border-slate-200">
        {{ form_widget(form.status, {'attr': {'class': 'h-5 w-5 rounded text-blue-600 focus:ring-blue-500 border-slate-300 transition-all cursor-pointer'}}) }}
        <div>
            {{ form_label(form.status, 'Salle active', {'label_attr': {'class': 'block text-sm font-semibold text-slate-900 cursor-pointer'}}) }}
            <p class="text-xs text-slate-500">Rendre la salle sélectionnable pour les événements.</p>
        </div>
        {% if form.status.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.status) }}
            </div>
        {% endif %}
    </div>

    {# --- Case à cocher : Mise en avant --- #}
    <div class="flex items-center gap-3 bg-slate-50 p-4 rounded-xl border border-slate-200">
        {{ form_widget(form.miseEnAvant, {'attr': {'class': 'h-5 w-5 rounded text-blue-600 focus:ring-blue-500 border-slate-300 transition-all cursor-pointer'}}) }}
        <div>
            {{ form_label(form.miseEnAvant, 'Mettre en avant', {'label_attr': {'class': 'block text-sm font-semibold text-slate-900 cursor-pointer'}}) }}
            <p class="text-xs text-slate-500">Mettre en valeur cette salle sur la page d'accueil.</p>
        </div>
        {% if form.miseEnAvant.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.miseEnAvant) }}
            </div>
        {% endif %}
    </div>

    {# --- Champ : Description (Pleine largeur sur la grille) --- #}
    <div class="md:col-span-3">
        {{ form_label(form.description, 'Description de la salle', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.description, {'attr': {
            'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900 h-32 resize-none',
            'placeholder': 'Spécificités techniques, équipements disponibles...'
        }}) }}
        {% if form.description.vars.errors|length > 0 %}
            <div class="mt-1.5 text-xs text-rose-600 font-medium flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i> {{ form_errors(form.description) }}
            </div>
        {% endif %}
    </div>

</div>

{# --- Actions du formulaire --- #}
<div class="flex items-center justify-end gap-4 pt-4 border-t border-slate-100 mt-6">
    <a href="{{ path('admin_salle_index') }}" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800 transition-colors">
        <i class="fa-solid fa-arrow-left"></i>
        <span>Retour à la liste</span>
    </a>
    <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md shadow-blue-500/20 hover:shadow-blue-500/30 transition-all transform hover:-translate-y-0.5">
        <i class="fa-solid fa-floppy-disk"></i>
        <span>{{ button_label|default('Enregistrer la salle') }}</span>
    </button>
</div>

{{ form_end(form) }}