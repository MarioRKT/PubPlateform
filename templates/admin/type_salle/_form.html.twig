{{ form_start(form) }}

<div class="space-y-5">

	<div>
		{{ form_label(form.nom, null, {
        'label_attr': {
            'class': 'block text-sm font-medium text-slate-700 mb-2'
        }
    }) }}

		{{ form_widget(form.nom, {
        'attr': {
            'class': 'w-full rounded-lg border border-slate-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent'
        }
    }) }}

		{{ form_errors(form.nom) }}
	</div>

	<button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
		<i class="fa-solid fa-floppy-disk mr-2"></i>
		{{ button_label|default('Enregistrer') }}
	</button>
	

</div>

{{ form_end(form) }}
