{% extends 'base.html.twig' %}

{% block title %}Nouveau Type de Salle{% endblock %}

{% block body %}

<div class="max-w-3xl mx-auto px-6 py-8">

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">
        Ajouter un Type de Salle
    </h1>
    <p class="text-sm text-slate-500 mt-1">
        Créez une nouvelle catégorie de salle.
    </p>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">

    {{ include('admin/type_salle/_form.html.twig') }}

</div>

<div class="mt-6">
    <a href="{{ path('admin_salle_index') }}"
       class="inline-flex items-center gap-2 text-slate-600 hover:text-blue-600 transition-colors">
        <i class="fa-solid fa-arrow-left"></i>
        Retour à la liste
    </a>
</div>

</div>
{% endblock %}

