{% extends 'base.html.twig' %}

{% block title %}Détail Type de Salle
{% endblock %}

{% block body %}

	<div class="max-w-4xl mx-auto px-6 py-8">

		<div class="mb-6">
			<h1 class="text-2xl font-bold text-slate-800">
				Détail du Type de Salle
			</h1>
			<p class="text-sm text-slate-500 mt-1">
				Consultation des informations du type de salle.
			</p>
		</div>

		<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">

			<table class="w-full">
				<tbody class="divide-y divide-slate-100">

					<tr>
						<th class="w-1/3 px-6 py-4 bg-slate-50 text-left text-sm font-semibold text-slate-600">
							ID
						</th>
						<td class="px-6 py-4 text-slate-800">
							#{{ type_salle.id }}
						</td>
					</tr>

					<tr>
						<th class="px-6 py-4 bg-slate-50 text-left text-sm font-semibold text-slate-600">
							Nom
						</th>
						<td class="px-6 py-4 text-slate-800">
							{{ type_salle.nom }}
						</td>
					</tr>

				</tbody>
			</table>

		</div>

		<div class="mt-6 flex items-center gap-3">

			<a href="{{ path('admin_salle_index') }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
				<i class="fa-solid fa-arrow-left"></i>
				Retour
			</a>

			<a href="{{ path('admin_salle_edit', {'id': type_salle.id}) }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors">
				<i class="fa-solid fa-pen-to-square"></i>
				Modifier
			</a>

			<div>
				{{ include('admin/type_salle/_delete_form.html.twig') }}
			</div>

		</div>

	</div>
{% endblock %}
