{% extends 'base.html.twig' %}

{% block title %}Configuration générale
{% endblock %}

{% block body %}
	<div
		class="p-8 space-y-16">

		{# ==================== SECTION 1 : GESTION DES MENUS ==================== #}
		<section>
			<!-- En-tête -->
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
				<div>
					<h2 class="text-xl font-bold text-slate-800 tracking-tight uppercase">Gestion des menus</h2>
					<p class="text-sm text-slate-500 mt-1">Consultez, organisez et gérez les liens de navigation.</p>
				</div>
				<a href="{{ path('admin_menu_new') }}" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm py-2.5 px-4 rounded-xl shadow-lg shadow-blue-500/10 transition-all transform hover:-translate-y-0.5 self-start sm:self-auto">
					<i class="fa-solid fa-plus"></i>
					Créer un menu
				</a>
			</div>

			<!-- Tableau des Menus -->
			<div class="overflow-x-auto bg-white rounded-2xl border border-slate-100 shadow-sm">
				<table class="w-full text-left border-collapse">
					<thead>
						<tr class="bg-slate-50 border-b border-slate-100 text-xs font-semibold text-slate-500 uppercase tracking-wider">
							<th class="py-4 px-6 w-24">Id</th>
							<th class="py-4 px-6">Nom</th>
							<th class="py-4 px-6">Status</th>
							<th class="py-4 px-6">Type Lien</th>
							<th class="py-4 px-6">Ordre</th>
							<th class="py-4 px-6 text-right w-36">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-100 text-sm">
						{% for menu in menus %}
							<tr
								class="hover:bg-slate-50/50 transition-colors">
								<!-- ID -->
								<td class="py-4 px-6 text-slate-400 font-mono text-xs">#{{ menu.id }}</td>

								<!-- Nom -->
								<td class="py-4 px-6 font-semibold text-slate-800">{{ menu.nom }}</td>

								<!-- Statut (Badge dynamique) -->
								<td class="py-4 px-6">
									{% if menu.status %}
										<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
											<span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
											Actif
										</span>
									{% else %}
										<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-50 text-rose-700">
											<span class="h-1.5 w-1.5 rounded-full bg-rose-400"></span>
											Inactif
										</span>
									{% endif %}
								</td>

								<!-- Type Lien (Badge neutre) -->
								<td class="py-4 px-6">
									<span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-gray-50 text-gray-600 border border-gray-150">
										{{ menu.typeLien }}
									</span>
								</td>

								<!-- Ordre -->
								<td class="py-4 px-6 text-slate-600 font-mono font-medium">{{ menu.ordre }}</td>

								<!-- Actions -->
								<td class="py-4 px-6 text-right">
									<div class="inline-flex items-center gap-2">
										<a href="{{ path('admin_menu_show', {'id': menu.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Voir">
											<i class="fa-solid fa-eye"></i>
										</a>
										<a href="{{ path('admin_menu_edit', {'id': menu.id}) }}" class="p-1.5 rounded-lg text-slate-400 hover:text-[#F96C2F] hover:bg-[#F96C2F]/10 transition-colors" title="Modifier">
											<i class="fa-solid fa-pen-to-square"></i>
										</a>
										{{ include('admin/menu/_delete_form.html.twig') }}
									</div>
								</td>
							</tr>
						{% else %}
							<!-- État vide -->
							<tr>
								<td colspan="6" class="py-12 text-center text-slate-400">
									<i class="fa-regular fa-folder-open text-4xl mb-3 block text-slate-300"></i>
									Aucun menu trouvé.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</section>

		<hr
		class="border-slate-100">

		{# ==================== SECTION 2 : CONFIGURATION DU SITE ==================== #}
		<section>
			<!-- En-tête -->
			<div class="mb-8">
				<h2 class="text-xl font-bold text-slate-800 tracking-tight uppercase">Paramètres du site</h2>
				<p class="text-sm text-slate-500 mt-1">Modifiez le logo, le favicon, le titre et autres paramètres globaux.</p>
			</div>

			<!-- Formulaire de Configuration -->
			<div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
				{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

				{# Grille Principale des Champs #}
				<div
					class="grid grid-cols-1 md:grid-cols-2 gap-6">

					{# Colonne Gauche #}
					<div
						class="space-y-4">
						{# Titre de la page #}
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-2">Titre de la page</label>
							{{ form_widget(form.titrePage, {'attr': {'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900'}}) }}
						</div>

						{# Copyright #}
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-2">Texte de copyright</label>
							{{ form_widget(form.copyright, {'attr': {'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900'}}) }}
						</div>

						{# Lien Site Web #}
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-2">URL du site web</label>
							{{ form_widget(form.lienSiteWeb, {'attr': {'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900'}}) }}
						</div>
					</div>

					{# Colonne Droite #}
					<div
						class="space-y-4">
						{# Nombre max de menus #}
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-2">Nombre maximum de menus</label>
							{{ form_widget(form.nbrMaxMenu, {'attr': {'class': 'w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent transition-all text-slate-900'}}) }}
						</div>

						{# Activation Paiement (Box d'activation) #}
						<div class="flex items-center gap-3 bg-slate-50 p-4 rounded-xl border border-slate-200 mt-2">
							{{ form_widget(form.activationPaiement, {'attr': {'class': 'h-5 w-5 rounded text-blue-600 focus:ring-blue-500 border-slate-300 transition-all cursor-pointer'}}) }}
							<div>
								<label class="block text-sm font-semibold text-slate-900 cursor-pointer">Activer la passerelle de paiement</label>
								<p class="text-xs text-slate-500">Cochez pour autoriser les transactions et achats de billets en ligne.</p>
							</div>
						</div>
					</div>
				</div>

				<hr
				class="border-slate-100 my-6">

				{# Section Médias (Logos & Favicon) #}
				<div
					class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{# Upload Logo #}
					<div class="bg-slate-50/50 p-5 rounded-2xl border border-slate-100 flex flex-col justify-between">
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-3">Logo du site</label>
							{% if config.logo %}
								<div class="bg-white p-3 rounded-xl border border-slate-200 inline-block mb-4 shadow-sm">
									<img src="{{ asset('uploads/site/' ~ config.logo) }}" alt="Logo" class="h-12 object-contain">
								</div>
							{% endif %}
						</div>
						{{ form_widget(form.logoFile, {'attr': {'class': 'w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-all cursor-pointer'}}) }}
					</div>

					{# Upload Favicon #}
					<div class="bg-slate-50/50 p-5 rounded-2xl border border-slate-100 flex flex-col justify-between">
						<div>
							<label class="block text-sm font-semibold text-slate-700 mb-3">Favicon (Icône de l'onglet)</label>
							{% if config.favicon %}
								<div class="bg-white p-3 rounded-xl border border-slate-200 inline-block mb-4 shadow-sm">
									<img src="{{ asset('uploads/site/' ~ config.favicon) }}" alt="Favicon" class="h-8 w-8 object-contain">
								</div>
							{% endif %}
						</div>
						{{ form_widget(form.faviconFile, {'attr': {'class': 'w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-all cursor-pointer'}}) }}
					</div>
				</div>

				{# Bouton de validation signature orange #}
				<div class="flex items-center justify-end pt-4 border-t border-slate-100 mt-6">
					<button type="submit" class="inline-flex items-center gap-2 bg-[#F96C2F] hover:bg-orange-600 text-white font-semibold text-sm py-2.5 px-6 rounded-xl shadow-lg shadow-orange-500/10 transition-all transform hover:-translate-y-0.5">
						<i class="fa-solid fa-floppy-disk"></i>
						Enregistrer les modifications
					</button>
				</div>

				{{ form_end(form) }}
			</div>
		</section>

	</div>

{% endblock %}
